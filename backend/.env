ENVIRONMENT=production
DEBUG=false

# Proveedor activo
DB_PROVIDER=postgres

# Cadenas de conexion
DB_SQLSERVER=Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=innovacion_curricular;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_SQLSERVEREXPRESS=Driver={ODBC Driver 17 for SQL Server};Server=localhost\SQLEXPRESS;Database=innovacion_curricular;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_LOCALDB=Driver={ODBC Driver 17 for SQL Server};Server=(localdb)\MSSQLLocalDB;Database=innovacion_curricular;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_POSTGRES=postgresql+asyncpg://postgres:postgres@localhost:5432/innovacion_curricular
DB_MYSQL=Server=localhost;Port=3306;Database=innovacion_curricular;User=postgres;Password=postgres;CharSet=utf8mb4;
DB_MARIADB=Server=localhost;Port=3306;Database=innovacion_curricular;User=postgres;Password=postgres;